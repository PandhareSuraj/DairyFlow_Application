SUPABASE_URL=https://utzvslmzjdtwbhzrolje.supabase.co
SUPABASE_PUBLISHABLE_KEY=PASTE_SUPABASE_ANON_OR_PUBLISHABLE_KEY
SUPABASE_KEY=PASTE_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Set these as Supabase Edge Function secrets, not Android values:
# MYOPERATOR_BASE_URL=https://publicapi.myoperator.co
# MYOPERATOR_COMPANY_ID=PASTE_COMPANY_ID
# MYOPERATOR_AUTH_TOKEN=PASTE_AUTH_TOKEN
# MYOPERATOR_AUTH_MODE=bearer
# MYOPERATOR_PHONE_NUMBER_ID=PASTE_PHONE_NUMBER_ID
# MYOPERATOR_TEMPLATE_NAME=otp_verify
# MYOPERATOR_TEMPLATE_OTP_VARIABLE=otp
# MYOPERATOR_SEND_TEMPLATE_PATH=/chat/messages
# MYOPERATOR_TEMPLATE_INCLUDE_LANGUAGE=false
# Deploy auth-whatsapp with the same Supabase Edge Function secrets.
# Android must only contain SUPABASE_URL and SUPABASE_KEY / SUPABASE_PUBLISHABLE_KEY.
# Never put MYOPERATOR_AUTH_TOKEN or WHATSAPP_API_KEY in the Android app.

# Legacy names from the older send-whatsapp-message function are also accepted:
# WHATSAPP_API_KEY=PASTE_AUTH_TOKEN
# WHATSAPP_COMPANY_ID=PASTE_COMPANY_ID
# WHATSAPP_PHONE_NUMBER_ID=PASTE_PHONE_NUMBER_ID
